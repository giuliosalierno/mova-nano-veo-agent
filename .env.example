# Google Cloud Project ID for Vertex AI
# Get it from: https://console.cloud.google.com/
GOOGLE_CLOUD_PROJECT=your-project-id-here

# Google Cloud Region for Vertex AI (must be regional, not "global")
GOOGLE_CLOUD_LOCATION=us-central1

# GCS bucket for storing generated images/videos across requests
LOGS_BUCKET_NAME=your-project-id-mova-artifacts
